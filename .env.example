# ==============================================================================
# RECRUITMENT SYSTEM DOCKER ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and modify values to suit your environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (PostgreSQL)
# ------------------------------------------------------------------------------
# Used by both the Postgres container and the backend service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=recruitment_db
# Port mapping on the host machine (change if host port 5432 is already in use)
DB_HOST_PORT=5432

# Connection settings for backend
PG_USER=postgres
PG_PASSWORD=postgres_password
PG_DATABASE=recruitment_db
# In docker-compose, this must match the database service name: "db"
PG_HOST=db
PG_PORT=5432

# ------------------------------------------------------------------------------
# 2. CACHE & SESSION CONFIGURATION (Redis)
# ------------------------------------------------------------------------------
USE_REDIS=true
# In docker-compose, this must match the Redis service name: "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_TIME_OUT=3600

# ------------------------------------------------------------------------------
# 3. BACKEND API CONFIGURATION (Express)
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=production
# Public absolute URL of the backend API (accessible from the browser client)
HOST=http://localhost:3000
# Target frontend URL for CORS, callback routes, etc.
CLIENT_URL=http://localhost:80

# ------------------------------------------------------------------------------
# 4. AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------
SECRET_AUTH_TOKEN_KEY=recruitment_super_secret_token_key_change_me
EXPIRES_TOKEN=15m
EXPIRES_REFRESH_TOKEN=30d

# ------------------------------------------------------------------------------
# 5. THIRD-PARTY SERVICES & INTEGRATIONS
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=google-client-id-template
CO_API_KEY=co-api-key-demo

# ------------------------------------------------------------------------------
# 6. STORAGE & FILE UPLOADS
# ------------------------------------------------------------------------------
# Directory inside the backend container where uploads are saved
PATH_SAVE_FILE=/app/uploads

# ------------------------------------------------------------------------------
# 7. FRONTEND BUILD TIME CONFIGURATION
# ------------------------------------------------------------------------------
# Backend API base URL used at compile time by Vite.
# Must be accessible from the user's web browser.
VITE_API_URL=http://localhost:3000
# Exposed port for the frontend Nginx web server on the host machine
FRONTEND_PORT=80

# ------------------------------------------------------------------------------
# 8. BACKUP CONFIGURATION
# ------------------------------------------------------------------------------
# Directory where database and file backups will be saved (can be relative or absolute)
BACKUP_DIR=./backups
