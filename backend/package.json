{
  "name": "recruitment_system",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "// === COMPILE & TYPE CHECK ===": "",
    "check": "tsc --noEmit",
    "build": "tspc",
    "// === MIGRATION & INIT DB ===": "",
    "init-db": "ts-node -v >/dev/null 2>&1 && ts-node utilities/generate-init-sql.ts || node dist/utilities/generate-init-sql.js",
    "run-init-db": "ts-node -v >/dev/null 2>&1 && ts-node utilities/run-init-sql.ts || node dist/utilities/run-init-sql.js",
    "check-db": "ts-node -v >/dev/null 2>&1 && ts-node utilities/check-db.ts || node dist/utilities/check-db.js",
    "// === TESTING ===": "",
    "test": "ts-mocha -p tsconfig.json --paths --timeout 30000 --exit \"test/**/*.test.ts\"",
    "test:file": "ts-mocha -p tsconfig.json --paths --timeout 30000 --exit",
    "test:coverage": "nyc ts-mocha -p tsconfig.json --paths --exit \"test/**/*.test.ts\"",
    "// === DEVELOPMENT ===": "",
    "start": "nodemon index.ts",
    "dev": "pm2 kill && pm2 update && pm2 delete all && mkdir -p logs && pm2 start ecosystem.config.cjs --update-env --watch",
    "// === PRODUCTION (PM2) ===": "",
    "startServer": "pm2 kill && pm2 update && pm2 delete all && mkdir -p logs && pm2 start ecosystem.config.cjs --update-env --no-daemon",
    "restart": "pm2 reload novel-server || npm run dev",
    "stop": "pm2 kill && pm2 delete all",
    "flush": "pm2 flush",
    "// === MONITORING & LOGS ===": "",
    "logs": "pm2 logs novel-server",
    "monit": "pm2 monit",
    "list": "pm2 list",
    "// === BACKUP ===": "",
    "backup": "ts-node utilities/backup_volumes.ts",
    "restore": "ts-node utilities/restore_volumes.ts"
  },
  "nyc": {
    "all": true,
    "check-coverage": true,
    "lines": 0,
    "functions": 0,
    "branches": 0,
    "statements": 0,
    "include": [
      "Model/**/*.ts",
      "services/**/*.ts",
      "utilities/**/*.ts",
      "middlewares/**/*.ts",
      "Controller/**/*.ts"
    ],
    "exclude": [
      "node_modules",
      "test/**/*.ts",
      "**/*.d.ts"
    ],
    "reporter": [
      "text",
      "lcov",
      "text-summary"
    ],
    "extension": [
      ".ts"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
