    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "node-stream-zip": "^1.15.0",
    "nodemailer": "^7.0.10",
    "nodemon": "^3.1.11",
    "nyc": "^17.1.0",
    "pactum": "^3.8.0",
